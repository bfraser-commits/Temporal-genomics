                // Set our new population size
                p5.setSubpopulationSize(new_size_p5);
               }                    
                        
 // Output VCF files for specific generations
    if (sim.cycle == 8) {
        sampled_individuals = sample(p2.individuals, 10).haplosomes;
        sampled_individuals.outputHaplosomesToVCF(OUTPUT_PREFIX + "_CA_generation_8.vcf");
         sampled_individuals_p3 = sample(p3.individuals, 12).haplosomes;
        sampled_individuals_p3.outputHaplosomesToVCF(OUTPUT_PREFIX + "_TA_generation_8.vcf");
    }
    else if (sim.cycle == 10) {
    	 sampled_individuals_p4 = sample(p4.individuals, 13).haplosomes;
        sampled_individuals_p4.outputHaplosomesToVCF(OUTPUT_PREFIX + "_LL_generation_8.vcf");
         sampled_individuals_p5 = sample(p5.individuals, 13).haplosomes;
        sampled_individuals_p5.outputHaplosomesToVCF(OUTPUT_PREFIX + "_UL_generation_8.vcf");
     }   
    else if (sim.cycle == 18) {
        sampled_individuals = sample(p2.individuals, 22).haplosomes;
    //    sampled_individuals.outputHaplosomesToVCF(OUTPUT_PREFIX + "_generation_18.vcf");
    	sampled_individuals.outputHaplosomesToVCF(OUTPUT_PREFIX + "_CA_generation18.vcf");
    	sampled_individuals_p3 = sample(p3.individuals, 23).haplosomes;
    	sampled_individuals_p3.outputHaplosomesToVCF(OUTPUT_PREFIX + "_TA_generation18.vcf");
    	}
    	
    	else if (sim.cycle == 22) {
    	sampled_individuals_p4 = sample(p4.individuals, 22).haplosomes;
   	sampled_individuals_p4.outputHaplosomesToVCF(OUTPUT_PREFIX + "_LL_generation18.vcf");
   	sampled_individuals_p5 = sample(p5.individuals, 24).haplosomes;
   	sampled_individuals_p5.outputHaplosomesToVCF(OUTPUT_PREFIX + "_UL_generation18.vcf");
