initialize() {
initializeSLiMOptions(nucleotideBased=T);
length = initializeAncestralNucleotides("STAR.chr22_noNCap.fa");
defineConstant("L", length); 
initializeMutationTypeNuc("m1", 0.5, "f", 0.0);
//initializeGenomicElementType("g1", m1, 1.0);
initializeGenomicElementType("g1", m1, 1.0, mmJukesCantor(0.0));
initializeGenomicElement(g1, 0, L-1);
initializeRecombinationRate(1e-8);

}
1 late() {
sim.addSubpop("p1", 19);
p1.haplosomes.readHaplosomesFromVCF("GH_chr22.recode.vcf", m1);
p1.setSubpopulationSize(20000);

// Make our p2
	sim.addSubpopSplit("p2",20000,p1);

//make p3
	sim.addSubpopSplit("p3", 20000, p1);
	
//make p4	
	sim.addSubpopSplit("p4", 20000, p1);

//make p5
	sim.addSubpopSplit("p5", 20000, p1);
	
	// Kill our p1
	p1.setSubpopulationSize(0);
	
	// Sample 20 individuals and output VCF at generation 1
    sampled_individuals = sample(p2.individuals, 20).haplosomes;
    sampled_individuals.outputHaplosomesToVCF(OUTPUT_PREFIX + "_generation_1.vcf");
//		sampled_individuals.outputHaplosomesToVCF("/Users/bonniefraser/Documents/FIBR_temporal/cvtk/slim5_slims/test_generation_1.vcf");


}

// From here on, we will read in the values from the demography file and create a new population
        2:24 late() {
         //late () {

      // demo_file = readFile(demo_data);
			demo_file_p2 = readFile("data/CA_2018_simulation_demography_min.txt");    
			demo_file_p3 = readFile("data/TY_2018_simulation_demography_min.txt");
			demo_file_p4 = readFile("data/LL_2018_simulation_demography_min.txt");
			demo_file_p5 = readFile("data/UL_2018_simulation_demography_min.txt");
			
        total_generations_p2 = length(demo_file_p2);
        total_generations_p3 = length(demo_file_p3);
        total_generations_p4 = length(demo_file_p4);
        total_generations_p5 = length(demo_file_p5);
         
   //p2 demographics      
                if(sim.cycle > 1 & sim.cycle <= total_generations_p2){
                //if(sim.cycle > 1) {
                // Fetch our demography values (-1 here as zero indexed and we have column names)
                female_mean = asFloat(strsplit(demo_file_p2[sim.cycle-1],"\t")[1]);
                female_sd = asFloat(strsplit(demo_file_p2[sim.cycle-1],"\t")[2]);
                male_mean = asFloat(strsplit(demo_file_p2[sim.cycle-1],"\t")[3]);
                male_sd = asFloat(strsplit(demo_file_p2[sim.cycle-1],"\t")[4]);
                
                // Calculate new size with error
                new_size_p2 = asInteger(rnorm(1,female_mean,female_sd) + rnorm(1,male_mean,male_sd));
                
                // Set our new population size
                p2.setSubpopulationSize(new_size_p2);
               }
  //p3 demographics
  			if(sim.cycle > 1 & sim.cycle <= total_generations_p3){
                //if(sim.cycle > 1) {
                // Fetch our demography values (-1 here as zero indexed and we have column names)
                female_mean_p3 = asFloat(strsplit(demo_file_p3[sim.cycle-1],"\t")[1]);
                female_sd_p3 = asFloat(strsplit(demo_file_p3[sim.cycle-1],"\t")[2]);
