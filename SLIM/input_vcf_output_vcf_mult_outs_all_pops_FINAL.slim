               }
    
    //p4 demographics
  			if(sim.cycle > 1 & sim.cycle <= total_generations_p4){
                female_mean_p4 = asFloat(strsplit(demo_file_p4[sim.cycle-1],"\t")[1]);
                female_sd_p4 = asFloat(strsplit(demo_file_p4[sim.cycle-1],"\t")[2]);
                male_mean_p4 = asFloat(strsplit(demo_file_p4[sim.cycle-1],"\t")[3]);
                male_sd_p4 = asFloat(strsplit(demo_file_p4[sim.cycle-1],"\t")[4]);
                
                // Calculate new size with error
                new_size_p4 = asInteger(rnorm(1,female_mean_p4,female_sd_p4) + rnorm(1,male_mean_p4,male_sd_p4));
                
                // Set our new population size
