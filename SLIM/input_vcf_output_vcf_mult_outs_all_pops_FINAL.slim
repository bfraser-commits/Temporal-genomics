                male_sd_p3 = asFloat(strsplit(demo_file_p3[sim.cycle-1],"\t")[4]);
                
                // Calculate new size with error
                new_size_p3 = asInteger(rnorm(1,female_mean_p3,female_sd_p3) + rnorm(1,male_mean_p3,male_sd_p3));
                
                // Set our new population size
